{
  "training": {
    "corpus_path": "data/cleaned/final_sonnets_corpus.txt",
    "output_dir": "outputs",
    "run_name": "baseline",
    "seed": 42,
    "batch_size": 32,
    "learning_rate": 0.0003,
    "weight_decay": 0.1,
    "training_steps": 40000,
    "warmup_steps": 1000,
    "eval_batches": 32,
    "log_interval": 200,
    "eval_interval": 500,
    "sample_interval": 1000,
    "checkpoint_interval": 2000,
    "sample_tokens": 512,
    "grad_clip": 1.0,
    "temperature": 0.9,
    "top_k": 40,
    "device": "auto",
    "plot_curves": true
  },
  "model": {
    "vocab_size": 132,
    "context_length": 256,
    "n_layers": 6,
    "d_model": 256,
    "n_heads": 8,
    "dropout": 0.1,
    "mlp_ratio": 4,
    "attention_backend": "sdpa",
    "position_embedding": "learned"
  },
  "vocab_size": 132,
  "device": "mps"
}